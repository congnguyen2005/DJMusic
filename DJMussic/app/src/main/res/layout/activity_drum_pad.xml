<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/card_bg"
        app:titleTextColor="@color/text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Volume Control -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Volume"
                        android:textColor="@color/accent"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <SeekBar
                            android:id="@+id/volume_seekbar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="80" />

                        <TextView
                            android:id="@+id/volume_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="80%"
                            android:textColor="@color/text_primary"
                            android:layout_marginStart="16dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BPM Control -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tempo (BPM)"
                        android:textColor="@color/accent"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <SeekBar
                            android:id="@+id/bpm_seekbar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="200"
                            android:progress="120" />

                        <TextView
                            android:id="@+id/bpm_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="120 BPM"
                            android:textColor="@color/text_primary"
                            android:layout_marginStart="16dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Drum Pads Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="4">

                <ImageButton
                    android:id="@+id/pad_kick"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@color/accent"
                    android:src="@drawable/ic_drum_pad"
                    android:scaleType="center"
                    android:alpha="0.9" />

                <ImageButton
                    android:id="@+id/pad_snare"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@color/accent"
                    android:src="@drawable/ic_drum_pad"
                    android:scaleType="center"
                    android:alpha="0.9" />

                <ImageButton
                    android:id="@+id/pad_hihat"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@color/accent"
                    android:src="@drawable/ic_drum_pad"
                    android:scaleType="center"
                    android:alpha="0.9" />

                <ImageButton
                    android:id="@+id/pad_crash"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@color/accent"
                    android:src="@drawable/ic_drum_pad"
                    android:scaleType="center"
                    android:alpha="0.9" />

                <ImageButton
                    android:id="@+id/pad_tom1"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@color/accent"
                    android:src="@drawable/ic_drum_pad"
                    android:scaleType="center"
                    android:alpha="0.9" />

                <ImageButton
                    android:id="@+id/pad_tom2"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@color/accent"
                    android:src="@drawable/ic_drum_pad"
                    android:scaleType="center"
                    android:alpha="0.9" />

                <ImageButton
                    android:id="@+id/pad_ride"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@color/accent"
                    android:src="@drawable/ic_drum_pad"
                    android:scaleType="center"
                    android:alpha="0.9" />

                <ImageButton
                    android:id="@+id/pad_clap"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@color/accent"
                    android:src="@drawable/ic_drum_pad"
                    android:scaleType="center"
                    android:alpha="0.9" />
            </GridLayout>

            <!-- Control Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/record_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_mic"
                    android:layout_margin="8dp"
                    app:backgroundTint="@color/card_bg"
                    app:tint="@color/accent" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/play_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_play"
                    android:layout_margin="8dp"
                    android:enabled="false"
                    app:backgroundTint="@color/card_bg"
                    app:tint="@color/accent" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/stop_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_stop"
                    android:layout_margin="8dp"
                    app:backgroundTint="@color/card_bg"
                    app:tint="@color/accent" />

                <Button
                    android:id="@+id/clear_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/card_bg"
                    android:textColor="@color/accent" />

                <Button
                    android:id="@+id/save_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save"
                    android:layout_margin="8dp"
                    android:enabled="false"
                    android:backgroundTint="@color/card_bg"
                    android:textColor="@color/accent" />
            </LinearLayout>

            <!-- Saved Patterns -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saved Patterns"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/patterns_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>